{
  "name": "piren",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Piren: lightweight, local-first agent layer on top of Pi Coding Agent",
  "bin": {
    "piren": "dist/src/cli.js"
  },
  "scripts": {
    "prepare": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json && node -e \"require('fs').cpSync('public','dist/public',{recursive:true})\"",
    "smoke": "tsx scripts/smoke.ts"
  },
  "dependencies": {
    "typebox": "^1.0.55",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
